## 9. 粒子互動模式 ⭐

### 吸引場

```jsx
function attractParticles(particles, attractor, strength = 0.02) {
    const pos = particles.geometry.attributes.position.array;
    for (let i = 0; i < pos.length; i += 3) {
        const dx = attractor.position.x - pos[i];
        const dy = attractor.position.y - pos[i+1];
        const dz = attractor.position.z - pos[i+2];
        const dist = Math.sqrt(dx*dx + dy*dy + dz*dz);
        const force = strength / (dist + 0.5);
        pos[i] += dx * force;
        pos[i+1] += dy * force;
        pos[i+2] += dz * force;
    }
    particles.geometry.attributes.position.needsUpdate = true;
}

```

