### 7.2 契約年資計算

```tsx
function calculateContractAge(effectiveDate: string): {
  years: number;
  months: number;
  totalMonths: number;
} {
  const start = new Date(effectiveDate);
  const now = new Date();

  let years = now.getFullYear() - start.getFullYear();
  let months = now.getMonth() - start.getMonth();

  if (months < 0) {
    years--;
    months += 12;
  }

  // 契約年資從第 1 年起算
  const totalMonths = years * 12 + months;

  return {
    years: years + 1,              // 第 1 年、第 2 年...
    months: months + 1,            // 第 1 個月、第 2 個月...
    totalMonths: totalMonths + 1
  };
}

// 範例：2023-12-29 生效，現在 2026-01-28
// → 契約第 3 年第 2 個月（總第 26 個月）

