## 3. 家庭圖模組

### 3.1 功能說明

使用 Genogram（家系圖）風格呈現家庭成員關係，並連結各成員的保單資料。

### 3.2 視覺符號

| 符號 | 說明 |
| --- | --- |
| □ | 男性 |
| ○ | 女性 |
| □—○ | 婚姻關係 |
| ｜ | 親子關係 |
| ☀️ | 主被保人（焦點人物） |
| ╱╲ | 已故 |

### 3.3 資料結構

```tsx
// 家庭成員
interface FamilyMember {
  id: string;
  name: string;
  relationship: RelationType;
  gender: 'male' | 'female';
  birthDate?: string;
  age?: number;
  isDeceased?: boolean;
  isMainInsured?: boolean;           // 是否為主被保人

  // 關係連結
  spouseId?: string;
  parentIds?: string[];
  childrenIds?: string[];

  // 財務資料（用於規劃工具）
  annualIncome?: number;
  occupation?: string;
  occupationClass?: 1 | 2 | 3 | 4 | 5 | 6;

  // 保單連結
  policyIds?: string[];

  // 規劃選擇
  isSelectedForPlanning?: boolean;
}

// 關係類型
type RelationType =
  | 'self'           // 本人
  | 'spouse'         // 配偶
  | 'father'         // 父親
  | 'mother'         // 母親
  | 'father_in_law'  // 公公/岳父
  | 'mother_in_law'  // 婆婆/岳母
  | 'son'            // 兒子
  | 'daughter'       // 女兒
  | 'brother'        // 兄弟
  | 'sister'         // 姐妹
  | 'grandfather'    // 祖父/外公
  | 'grandmother'    // 祖母/外婆
  | 'grandson'       // 孫子
  | 'granddaughter'  // 孫女
  | 'other';         // 其他

// 家庭圖
interface FamilyTree {
  id: string;
  userId: string;                    // 建立者 ID
  name: string;                      // 家庭名稱（如「王家」）
  mainInsuredId: string;             // 主被保人 ID
  members: FamilyMember[];
  createdAt: string;
  updatedAt: string;
}

```

