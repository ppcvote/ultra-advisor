# =============================================================================
# Ultra Advisor — frontend environment variables
# Copy this file to .env.local for local dev, set in Vercel for prod.
# All VITE_* vars are exposed to the browser bundle — do NOT put secrets here.
# =============================================================================

# -----------------------------------------------------------------------------
# Observability (CRITICAL #6)
# -----------------------------------------------------------------------------
# Sentry DSN — when empty, Sentry SDK is no-op (no crash, one console.warn)
VITE_SENTRY_DSN=

# Force Sentry on in non-prod builds (set to "1" to enable in dev / preview)
VITE_SENTRY_FORCE=

# PostHog project key — when empty, analytics SDK is no-op
VITE_POSTHOG_KEY=

# PostHog ingest host. Use https://eu.i.posthog.com for the EU cluster.
VITE_POSTHOG_HOST=https://us.i.posthog.com
