rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- helper function: 檢查是否已登入 ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- helper function: 檢查是否是存取自己的資料 ---
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- helper function: 檢查是否為管理員 ---
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- helper function: 檢查 users 寫入是否觸碰受保護欄位（防 paywall 繞過）---
    function hasProtectedFieldChange() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['primaryTierId', 'tierId', 'role', 'plan', 'status', 'isAdmin',
                 'membershipTier', 'membershipExpiresAt', 'points', 'totalPoints']);
    }

    // ============================================
    // 1. 系統配置（公開讀取，管理員可寫）
    // ============================================
    match /membershipTiers/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pointsRules/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /missions/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /siteContent/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /redeemableItems/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // 2. 用戶相關資料
    // ============================================

    // 用戶資料：自己或管理員可讀寫
    // 🔒 SECURITY: 用戶不可自行修改會員等級/角色/付費狀態（防止 devtools 一行繞過 paywall）
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      // 建立：只有自己（首次註冊），但不可預設付費欄位
      allow create: if isSignedIn() && isOwner(userId)
                    && !request.resource.data.keys().hasAny(['primaryTierId', 'tierId', 'role', 'plan', 'isAdmin', 'membershipTier']);
      // 更新：自己可改，但不能動受保護欄位（除非是 admin）
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(userId) && !hasProtectedFieldChange())
      );
      // 刪除：只有 admin
      allow delete: if isAdmin();

      // 社群助理 - 發文紀錄：只能新增，不能修改和刪除（審計用途）
      match /threadsPosts/{docId} {
        allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
        allow create: if isSignedIn() && isOwner(userId);
        allow update, delete: if isAdmin();
      }

      // 子集合（profile, preferences, threadsConfig, threadsLibrary 等）
      match /{allSubcollections=**} {
         allow read, write: if isSignedIn() && (isOwner(userId) || isAdmin());
      }
    }

    // 點數帳本：自己可讀、管理員可讀，寫入由後端處理
    match /pointsLedger/{doc} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // 兌換訂單：自己可讀、管理員可讀寫
    match /redemptionOrders/{doc} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // 推薦碼：公開讀取（用於驗證推薦碼），寫入由後端處理
    match /referralCodes/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // 付款歷史：管理員可讀寫
    match /paymentHistory/{doc} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // 用戶建議：登入用戶可建立，管理員可讀寫
    match /feedbacks/{doc} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // 預約諮詢：任何人可提交，管理員可讀寫
    match /bookingRequests/{doc} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // 合作申請：任何人可提交，管理員可讀寫
    match /partnerApplications/{doc} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // FCM 推播 Token：自己可讀寫，管理員可讀（發送推播由後端處理）
    match /fcmTokens/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow write: if isSignedIn() && isOwner(userId);
    }

    // completedMissions collectionGroup 查詢（跨用戶查詢任務完成狀態）
    match /{path=**}/completedMissions/{doc} {
      allow read: if isAdmin();
    }

    // ============================================
    // 3. 管理員/系統資料
    // ============================================
    match /admins/{doc} {
      allow read: if isSignedIn();  // 登入者可讀（用於驗證身份）
      allow write: if false;        // 僅後端可寫（防止自行加入管理員）
    }
    match /backups/{doc} {
      allow read, write: if isAdmin();
    }
    match /auditLogs/{doc} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /rateLimits/{doc} {
      allow read, write: if false;
    }

    // ============================================
    // 4. 保單健診系統
    // ============================================

    // 險種快取資料庫：登入用戶可讀（自動完成搜尋），僅後端可寫
    match /productCache/{doc} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Sprint 13 — 保險商品 catalog（資料來自 TII 法定備查商品代碼/規格/生效日）
    // 登入顧問可讀（ProductPicker / InsuranceCheckup autoload），
    // 僅後端 admin SDK (ingest-catalog-to-firestore.cjs) 可寫。
    match /insurance_products/{doc} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Sprint 14 W2 — 條款 chunk + 768d embedding（RAG agent 用）
    // 登入顧問可讀（前端只在 /api/ask backend 內 query；KNN 結果回傳已過濾），
    // 僅後端 admin SDK (upload-chunks-to-firestore.cjs) 可寫。
    match /insurance_products/{productId}/chunks/{chunkId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Sprint 14 W1 — Crowd-sourced new-product补登 queue（顧問端 MissingProductModal）
    // 顧問遇到 catalog miss 時 1-click 補資料、走人工審核後納入 catalog（Sprint 15）。
    // - create: 必須登入、且 submittedBy 必須等於自己的 uid（防偽造）
    // - read / list: 僅 admin（顧問不可看別人的補登內容）
    // - update / delete: 僅 admin（審核 / 拒絕 / 升級）
    match /insurance_products_pending/{doc} {
      allow create: if isSignedIn()
                    && request.resource.data.submittedBy == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Sprint 14 W2 — RAG agent audit log（每月分桶，PII sanitized）
    // 結構：audit_logs/{yyyymm}/events/{eventId}
    // - read: admin only（合規稽核）
    // - write: backend admin SDK only（顧客端不直接寫）
    match /audit_logs/{yyyymm} {
      allow read: if isAdmin();
      allow write: if false;

      match /events/{eventId} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    // Sprint 14 W2 — 顧問每月 quota 使用量（ask 100/月、PDF view 50/月 W3 加）
    // 結構：advisors/{uid}/quotaUsage/{yyyymm}
    // - read: 顧問自己 + admin
    // - write: backend admin SDK only（避免顧問偽造 reset）
    match /advisors/{uid}/quotaUsage/{yyyymm} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    // Sprint 15 W2 — 條款修訂通知 fanout 後的 per-advisor alert
    // 結構：advisors/{uid}/conditionAlerts/{alertId}
    // - read: 顧問自己 + admin（跨顧問隔離靠 path uid 比對）
    // - create / delete: backend admin SDK only（notifyConditionRevision fanout 寫）
    // - update: 顧問自己僅可改 affectedClients + status（updateClientContactStatus）；
    //           其它欄位（diffSummary / productId / severity / createdAt 等）一律鎖死
    match /advisors/{uid}/conditionAlerts/{alertId} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create, delete: if false;
      allow update: if isSignedIn()
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['affectedClients', 'status']);
    }

    // Sprint 14 W2 — 顧問申請 quota 加額（達上限後提交 form）
    // - create: 登入顧問可提交
    // - read / update / delete: 僅 admin（審核/拒絕/批准）
    match /quota_extension_requests/{doc} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // Sprint 15 W1 — Versioned schema backfill 進度回報
    // 結構：backfill_progress/{runId}（runId 由 callable / CLI 產生）
    // - read: admin only（給 admin UI 拉進度條 / debug error samples）
    // - write: backend admin SDK only（callable / CLI 走 admin SDK 寫；顧問端零寫入）
    match /backfill_progress/{runId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Sprint 15 W1 — 統一審核 queue（TII 月排程 + 顧問補登 + 公司 scraper 三源匯流）
    // 結構：insurance_review_queue/{runMonth__changeKind__productId}
    // - read: admin only（顧問端絕對不暴露；rules + UI 雙重 gate）
    // - write: backend admin SDK only（crawler / callable 寫；顧問端零寫入避免偽造）
    // - 客戶 PII 嚴禁：寫入端負責 sanitize（MissingProductModal.sanitizeOcrSnapshot）
    match /insurance_review_queue/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Sprint 15 W1 — TII 月排程 raw 抓取結果（per-run diff report 鏡像）
    // 結構：tii_crawl_results/{runMonth}
    // - read: admin only（給 admin UI 看 captchaHitRate / partialCompanies / failed[]）
    // - write: backend admin SDK only（crawler --commit 收尾寫，顧問端零寫入）
    match /tii_crawl_results/{runMonth} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Sprint 17 W1 — Metrics Dashboard 預聚合 doc
    // 結構：metrics_daily/{yyyymmdd}（metricsAggregationDaily cron 每天 02:00 TW 寫）
    // - read: admin only（src/admin/MetricsDashboard.tsx 拉 19 個 KPI 卡片）
    // - write: backend admin SDK only（cron 寫；顧問端 / 一般用戶零寫入）
    // - 不含客戶 PII（payload 全是數字 / 計數 / 比率）
    match /metrics_daily/{yyyymmdd} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ============================================
    // 5. 每日市場報告（公開可讀，寫入由後端處理）
    // ============================================
    match /dailyMarketReports/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ============================================
    // 7. Ultra 白板（主持人需登入 + 必須是 presenterUid，size 上限 200KB）
    // ============================================
    // 🔒 SECURITY 修補項目：
    //  - 任何人有連結都能讀（demo 場景需要）
    //  - 必須登入才能建立 + 必須記下 presenterUid
    //  - 寫入限：必須登入 + uid == presenterUid + size < 200KB
    //  - presenterToken 移到 sibling private subcollection（未來工作），暫時公開檔內維持相容
    match /whiteboards/{roomId} {
      // 任何人有連結都能看
      allow read: if true;
      // 建立：需登入，且必須把自己的 uid 記為 presenterUid
      allow create: if isSignedIn()
                    && request.resource.data.presenterUid == request.auth.uid
                    && request.resource.size() < 200 * 1024;
      // 更新：必須登入 + 是 presenterUid + 大小限制 + 不能改 presenterUid/createdAt
      // 沒有 presenterUid 的舊文件（legacy）走 token 比對保留相容
      allow update: if isSignedIn()
                    && request.resource.size() < 200 * 1024
                    && request.resource.data.createdAt == resource.data.createdAt
                    && (
                      // 新規則：uid 必須是 presenterUid
                      (resource.data.presenterUid is string
                        && resource.data.presenterUid == request.auth.uid
                        && request.resource.data.presenterUid == resource.data.presenterUid)
                      ||
                      // 舊文件相容：沒 presenterUid，至少 token 不可被改
                      (!('presenterUid' in resource.data)
                        && request.resource.data.presenterToken == resource.data.presenterToken)
                    );
      // 不允許刪除
      allow delete: if false;

      // 歷史快照（已儲存的版本）— 登入用戶可建，size 限制
      match /history/{snapshotId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.size() < 200 * 1024;
        allow update, delete: if false;
      }
    }

    // ============================================
    // 8. 安全保底（預設拒絕）
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
